    <decisions>
        <description>Per the Voucher&apos;s Definition Redemption Channel does this voucher auto redeem upon issuance</description>
        <name>Auto_Redeem_Voucher</name>
        <label>Auto Redeem Voucher?</label>
        <locationX>0</locationX>
        <locationY>0</locationY>
        <defaultConnector>
            <targetReference>Set_Voucher_Values_0</targetReference>
        </defaultConnector>
        <defaultConnectorLabel>Default Outcome</defaultConnectorLabel>
        <rules>
            <name>Auto_Redeem_Outcome</name>
            <conditionLogic>and</conditionLogic>
            <conditions>
                <leftValueReference>var_IssuedVoucher.VoucherDefinition.Redemption_Channel__c</leftValueReference>
                <operator>EqualTo</operator>
                <rightValue>
                    <stringValue>Auto-redeem</stringValue>
                </rightValue>
            </conditions>
            <connector>
                <targetReference>Set_Voucher_Values</targetReference>
            </connector>
            <label>Auto Redeem</label>
        </rules>
    </decisions>
    <decisions>
        <name>Check_Voucher_Status</name>
        <label>Check Voucher Status</label>
        <locationX>0</locationX>
        <locationY>0</locationY>
        <defaultConnectorLabel>Default Outcome</defaultConnectorLabel>
        <rules>
            <name>Not_Issued_AND_Not_Closed</name>
            <conditionLogic>and</conditionLogic>
            <conditions>
                <leftValueReference>var_IssuedVoucher.Status</leftValueReference>
                <operator>NotEqualTo</operator>
                <rightValue>
                    <stringValue>Issued</stringValue>
                </rightValue>
            </conditions>
            <conditions>
                <leftValueReference>var_IssuedVoucher.Redemption_Processed__c</leftValueReference>
                <operator>EqualTo</operator>
                <rightValue>
                    <booleanValue>false</booleanValue>
                </rightValue>
            </conditions>
            <connector>
                <targetReference>Handle_Voucher_Redemption</targetReference>
            </connector>
            <label>Not Issued AND Not Closed</label>
        </rules>
    </decisions>
    <decisions>
        <description>Ensures that the TJ ID var is not null or empty</description>
        <name>Valid_Transaction_Journal_Id</name>
        <label>Valid Transaction Journal Id?</label>
        <locationX>0</locationX>
        <locationY>0</locationY>
        <defaultConnector>
            <targetReference>Set_Debug_Values</targetReference>
        </defaultConnector>
        <defaultConnectorLabel>Default Outcome</defaultConnectorLabel>
        <rules>
            <name>Valid_Transaction_Journal_Outcome</name>
            <conditionLogic>and</conditionLogic>
            <conditions>
                <leftValueReference>var_NewTransactionJournal</leftValueReference>
                <operator>IsNull</operator>
                <rightValue>
                    <booleanValue>false</booleanValue>
                </rightValue>
            </conditions>
            <connector>
                <targetReference>Auto_Redeem_Voucher</targetReference>
            </connector>
            <label>Valid Transaction Journal</label>
        </rules>
    </decisions>
    <decisions>
        <description>This flow should be called only when Voucher ISNew() is true, however, this step insures that the status of the Voucher is Issued before performing any actions.</description>
        <name>Voucher_Status</name>
        <label>Voucher Status?</label>
        <locationX>0</locationX>
        <locationY>0</locationY>
        <defaultConnector>
            <targetReference>Set_Debug_Details</targetReference>
        </defaultConnector>
        <defaultConnectorLabel>Default Outcome</defaultConnectorLabel>
        <rules>
            <name>Issued_Status</name>
            <conditionLogic>and</conditionLogic>
            <conditions>
                <leftValueReference>var_IssuedVoucher.Status</leftValueReference>
                <operator>EqualTo</operator>
                <rightValue>
                    <stringValue>Issued</stringValue>
                </rightValue>
            </conditions>
            <conditions>
                <leftValueReference>var_IssuedVoucher.Id</leftValueReference>
                <operator>IsNull</operator>
                <rightValue>
                    <booleanValue>false</booleanValue>
                </rightValue>
            </conditions>
            <connector>
                <targetReference>Create_Liability_Transaction_Journal</targetReference>
            </connector>
            <label>Issued</label>
        </rules>
    </decisions>
    <description>Executes the applicable business logic when a Voucher is newly issued to a Member.</description>
    <environments>Default</environments>
    <interviewLabel>LOY Subflow: Handle Voucher Issuance {!$Flow.CurrentDateTime}</interviewLabel>
    <label>LOY - Subflow - Handle Voucher Issuance</label>
    <processMetadataValues>
        <name>BuilderType</name>
        <value>
            <stringValue>LightningFlowBuilder</stringValue>
        </value>
    </processMetadataValues>
    <processMetadataValues>
        <name>CanvasMode</name>
        <value>
            <stringValue>AUTO_LAYOUT_CANVAS</stringValue>
        </value>
    </processMetadataValues>
    <processMetadataValues>
        <name>OriginBuilderType</name>
        <value>
            <stringValue>LightningFlowBuilder</stringValue>
        </value>
    </processMetadataValues>
    <processType>AutoLaunchedFlow</processType>
    <recordUpdates>
        <name>Update_Voucher_Record</name>
        <label>Update Voucher Record</label>
        <locationX>0</locationX>
        <locationY>0</locationY>
        <connector>
            <targetReference>Associate_TJ_with_Voucher</targetReference>
        </connector>
        <faultConnector>
            <targetReference>Set_Debug_Details_2</targetReference>
        </faultConnector>
        <inputReference>var_IssuedVoucher</inputReference>
    </recordUpdates>
    <recordUpdates>
        <name>Update_Voucher_Redemption_Processed</name>
        <label>Update Voucher Redemption Processed</label>
        <locationX>0</locationX>
        <locationY>0</locationY>
        <faultConnector>
            <targetReference>Set_Debug_Details_3</targetReference>
        </faultConnector>
        <filterLogic>and</filterLogic>
        <filters>
            <field>Id</field>
            <operator>EqualTo</operator>
            <value>
                <elementReference>var_IssuedVoucher.Id</elementReference>
            </value>
        </filters>
        <inputAssignments>
            <field>Redemption_Processed__c</field>
            <value>
                <booleanValue>true</booleanValue>
            </value>
        </inputAssignments>
        <object>Voucher</object>
    </recordUpdates>
    <start>
        <locationX>0</locationX>
        <locationY>0</locationY>
        <connector>
            <targetReference>Voucher_Status</targetReference>
        </connector>
    </start>
    <status>Active</status>
    <subflows>
        <name>Associate_TJ_with_Voucher</name>
        <label>Associate TJ with Voucher</label>
        <locationX>0</locationX>
        <locationY>0</locationY>
        <connector>
