                <stringValue>Redeemed</stringValue>
            </value>
        </assignmentItems>
        <assignmentItems>
            <assignToReference>var_IssuedVoucher.Issued__c</assignToReference>
            <operator>Assign</operator>
            <value>
                <booleanValue>true</booleanValue>
            </value>
        </assignmentItems>
        <assignmentItems>
            <assignToReference>var_IssuedVoucher.Redeemed__c</assignToReference>
            <operator>Assign</operator>
            <value>
                <booleanValue>true</booleanValue>
            </value>
        </assignmentItems>
        <assignmentItems>
            <assignToReference>var_IssuedVoucher.RateCategories__c</assignToReference>
