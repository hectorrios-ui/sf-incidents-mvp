                <elementReference>var_PriorVoucher</elementReference>
            </value>
        </inputAssignments>
        <inputAssignments>
            <name>var_Voucher</name>
            <value>
                <elementReference>var_IssuedVoucher</elementReference>
            </value>
        </inputAssignments>
        <inputAssignments>
            <name>varT_TransactionJournalContext</name>
            <value>
                <stringValue>Liability</stringValue>
            </value>
        </inputAssignments>
        <outputAssignments>
            <assignToReference>var_NewTransactionJournal</assignToReference>
            <name>var_NewTransactionJournal</name>
        </outputAssignments>
