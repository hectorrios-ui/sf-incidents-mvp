                <elementReference>var_NewTransactionJournal</elementReference>
            </value>
        </inputAssignments>
        <inputAssignments>
            <name>varVoucher</name>
            <value>
                <elementReference>var_IssuedVoucher</elementReference>
            </value>
        </inputAssignments>
    </subflows>
    <subflows>
        <description>Create the Debit Transaction Journal Entry</description>
        <name>Create_Liability_Transaction_Journal</name>
        <label>Create Liability Transaction Journal</label>
        <locationX>0</locationX>
        <locationY>0</locationY>
        <connector>
            <targetReference>Valid_Transaction_Journal_Id</targetReference>
        </connector>
        <flowName>Create_Liability_Transaction_Journal</flowName>
        <inputAssignments>
            <name>var_PriorVoucher</name>
