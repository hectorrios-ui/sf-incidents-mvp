    <decisions>
        <name>Check_Sub_Group_to_Calculate_GMTenure</name>
        <label>Check Sub Group to Calculate GMTenure</label>
        <locationX>182</locationX>
        <locationY>350</locationY>
        <defaultConnector>
            <targetReference>Set_GMStartDate_to_Null</targetReference>
        </defaultConnector>
        <defaultConnectorLabel>GMStartDate = null</defaultConnectorLabel>
        <rules>
            <name>GMStartDate_Today</name>
            <conditionLogic>(1 OR 2 OR 3) AND 4</conditionLogic>
            <conditions>
                <leftValueReference>Get_Employee.Employee_Sub_Group__c</leftValueReference>
                <operator>EqualTo</operator>
                <rightValue>
                    <stringValue>Company Owned or CMH General Managers</stringValue>
                </rightValue>
            </conditions>
            <conditions>
                <leftValueReference>Get_Employee.Employee_Sub_Group__c</leftValueReference>
                <operator>EqualTo</operator>
                <rightValue>
                    <stringValue>Franchise General Managers</stringValue>
                </rightValue>
            </conditions>
            <conditions>
                <leftValueReference>Get_Employee.Employee_Sub_Group__c</leftValueReference>
                <operator>EqualTo</operator>
                <rightValue>
                    <stringValue>Partner General Managers</stringValue>
                </rightValue>
            </conditions>
            <conditions>
                <leftValueReference>Get_Employee.EmployeeStatus</leftValueReference>
                <operator>NotEqualTo</operator>
                <rightValue>
                    <stringValue>Terminated</stringValue>
                </rightValue>
            </conditions>
            <connector>
                <targetReference>Set_GMStartDate_to_Today</targetReference>
            </connector>
            <label>GMStartDate = Today</label>
        </rules>
    </decisions>
