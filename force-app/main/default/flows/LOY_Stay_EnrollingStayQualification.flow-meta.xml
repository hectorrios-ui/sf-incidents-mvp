    <formulas>
        <name>Days1</name>
        <dataType>Number</dataType>
        <expression>IF(DATEVALUE({!lmlRecord.LOY_Enrollment_Date__c}) &gt;={!stayRecord.LOY_CheckInDate__c}, 0, 
{!stayRecord.LOY_CheckInDate__c}  - DATEVALUE({!lmlRecord.LOY_Enrollment_Date__c}) 
)</expression>
        <scale>2</scale>
    </formulas>
    <formulas>
        <name>Days2</name>
        <dataType>Number</dataType>
        <expression>IF({!stayRecord.LOY_CheckoutDate__c} &gt;= DATEVALUE({!lmlRecord.LOY_Enrollment_Date__c}), 0, 
 DATEVALUE({!lmlRecord.LOY_Enrollment_Date__c}) -  {!stayRecord.LOY_CheckoutDate__c}
)</expression>
