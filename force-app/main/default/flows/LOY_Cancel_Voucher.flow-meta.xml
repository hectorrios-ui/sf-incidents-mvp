        <rules>
            <name>Voucher_Expired</name>
            <conditionLogic>and</conditionLogic>
            <conditions>
                <leftValueReference>Get_Voucher_Record.ExpirationDate</leftValueReference>
                <operator>LessThan</operator>
                <rightValue>
                    <elementReference>$Flow.CurrentDate</elementReference>
                </rightValue>
            </conditions>
            <conditions>
                <leftValueReference>Get_Voucher_Record.ExpirationDate</leftValueReference>
                <operator>NotEqualTo</operator>
            </conditions>
