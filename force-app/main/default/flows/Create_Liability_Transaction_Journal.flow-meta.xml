    <description>US287238 - SFLC | Update all code using the Voucher Reimbursement Fields
US282548 - SFLC | Update Breakage flow for Data Source</description>
    <environments>Default</environments>
    <formulas>
        <description>Sources the transaction amount based on the context of the transaction journal.  For example, Reimbursement</description>
        <name>forC_TransactionAmount</name>
        <dataType>Currency</dataType>
        <expression>CASE ( {!varT_TransactionJournalContext}, 
&quot;Reimbursement&quot;, {!varC_ReimbursementAmount},
&quot;Liability&quot;, {!var_Voucher.VoucherDefinition.CostPerVoucher},
&quot;Breakage&quot;, {!Get_Redemption_Details_Record.Breakage_Amount__c},
0
)</expression>
        <scale>2</scale>
    </formulas>
    <formulas>
        <name>forN_ReimbursementAmount</name>
        <dataType>Number</dataType>
        <expression>CASE (
{!var_Voucher.VoucherDefinition.Reimbursement_Model__c},
&quot;Flat Rate&quot;,  IF ({!var_Voucher.VoucherDefinition.Reimbursement_Value__c}!=null, {!var_Voucher.VoucherDefinition.Reimbursement_Value__c}, 0),
&quot;PercentageVoucherValue&quot;,  IF ({!var_Voucher.VoucherDefinition.Reimbursement_Percentage__c}!=null, {!var_Voucher.FaceValue} * {!var_Voucher.VoucherDefinition.Reimbursement_Percentage__c}, 0),
&quot;PercentRedeemedAmount&quot;, IF ({!var_Voucher.VoucherDefinition.Reimbursement_Percentage__c}!=null, {!Get_Redemption_Details_Record.Voucher_Redeem_Amount__c} * {!var_Voucher.VoucherDefinition.Reimbursement_Percentage__c}, 0),  
0
)</expression>
        <scale>2</scale>
    </formulas>
    <formulas>
        <description>Represents the currency based on the context of the Transaction</description>
        <name>forT_CurrencyISOCode</name>
        <dataType>String</dataType>
        <expression>CASE ( {!varT_TransactionJournalContext}, 
&quot;Reimbursement&quot;, IF({!varT_CurrencyISOCode} != null, {!varT_CurrencyISOCode}, {!$Label.LOY_Default_Currency_ISO_Code}),
&quot;Liability&quot;, IF(TEXT({!var_Voucher.VoucherDefinition.CurrencyIsoCode}) != null, TEXT({!var_Voucher.VoucherDefinition.CurrencyIsoCode}), {!$Label.LOY_Default_Currency_ISO_Code} ),
&quot;Breakage&quot;,  IF(  TEXT({!Get_Redemption_Details_Record.CurrencyIsoCode}) != null, TEXT({!Get_Redemption_Details_Record.CurrencyIsoCode}) , {!$Label.LOY_Default_Currency_ISO_Code}),
{!$Label.LOY_Default_Currency_ISO_Code}
)</expression>
    </formulas>
    <formulas>
        <name>forT_LiabilitySubtype</name>
        <dataType>String</dataType>
        <expression>IF(ISPICKVAL({!var_Voucher.Status},&quot;Expired&quot;), &quot;Expired Voucher&quot;, 
	IF(ISPICKVAL({!var_Voucher.Status}, &quot;Cancelled&quot;), &quot;Cancelled Voucher&quot;, 
		IF(ISPICKVAL({!var_Voucher.Status}, &quot;Redeemed&quot;), &quot;Redeemed Voucher&quot;, 
			IF(ISPICKVAL({!var_Voucher.Status}, &quot;Issued&quot;) &amp;&amp; ISPICKVAL({!var_PriorVoucher.Status}, &quot;Redeemed&quot;), &quot;reaward&quot;, &quot;Awarded Voucher&quot;))))</expression>
    </formulas>
    <formulas>
        <description>Stores the impending status of the new TJ record as determined by the type.</description>
        <name>forT_NewTJStatus</name>
        <dataType>String</dataType>
        <expression>IF(
    OR(
        {!varT_TransactionJournalContext}=&apos;Reimbursement&apos;,
        {!varT_TransactionJournalContext}=&apos;Liability&apos;
    ), 
    IF(
        ISPICKVAL({!var_Voucher.VoucherDefinition.Redemption_Channel__c}, &apos;Auto-redeem&apos;),
        &apos;Pending&apos;,
        IF(
            OR(
                ISPICKVAL({!var_Voucher.Status}, &apos;Issued&apos;),
                ISPICKVAL({!var_Voucher.Status}, &apos;Redeemed&apos;),
                ISPICKVAL({!var_Voucher.Status}, &apos;Cancelled&apos;),
                ISPICKVAL({!var_Voucher.Status}, &apos;Expired&apos;)					
            ), 
            &apos;Processed&apos;, 
            &apos;Pending&apos;
        )
    ),
    &apos;Pending&apos;
)</expression>
    </formulas>
