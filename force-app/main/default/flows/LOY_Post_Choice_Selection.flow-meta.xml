    <decisions>
        <name>Any_Remaining_Choices</name>
        <label>Any Remaining Choices?</label>
        <locationX>0</locationX>
        <locationY>0</locationY>
        <defaultConnectorLabel>Default Outcome</defaultConnectorLabel>
        <rules>
            <name>No_Remaining_Choices_to_Select</name>
            <conditionLogic>and</conditionLogic>
            <conditions>
                <leftValueReference>Get_Member_Choice.Number_of_Choices__c</leftValueReference>
                <operator>LessThan</operator>
                <rightValue>
                    <numberValue>1.0</numberValue>
                </rightValue>
            </conditions>
            <connector>
                <targetReference>Set_Choice_Pre_Close_Status</targetReference>
            </connector>
            <label>No Remaining Choices to Select</label>
        </rules>
        <rules>
            <name>Additional_Choices_Remain</name>
            <conditionLogic>and</conditionLogic>
            <conditions>
                <leftValueReference>Get_Member_Choice.Number_of_Choices__c</leftValueReference>
                <operator>GreaterThanOrEqualTo</operator>
                <rightValue>
                    <numberValue>1.0</numberValue>
                </rightValue>
            </conditions>
            <connector>
                <targetReference>Successful_Response</targetReference>
            </connector>
            <label>Additional Choices Remain</label>
        </rules>
    </decisions>
    <decisions>
