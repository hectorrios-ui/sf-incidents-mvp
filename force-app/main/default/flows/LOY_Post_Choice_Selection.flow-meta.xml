    <description>US220900 - SFLC: RolloverMilestone - postChoiceBenefit selection - Include Choice Id instead of Benefit</description>
    <environments>Default</environments>
    <formulas>
        <description>15 char version of the benefit id used for matching</description>
        <name>Benefit_Id_15_Char</name>
        <dataType>String</dataType>
        <expression>LEFT({!ChoiceId}, 15)</expression>
    </formulas>
    <formulas>
        <name>forB_ValidInputPayload</name>
        <dataType>Boolean</dataType>
        <expression>AND( {!varB_ValidIssueQty}, TRUE)</expression>
    </formulas>
    <formulas>
        <name>forB_ValidIssueQuantity</name>
        <dataType>Boolean</dataType>
        <expression>{!IssueQty} &gt; 0</expression>
    </formulas>
    <formulas>
        <description>Issue Qty is defaulted to 1 if an invalid IssueQty is provided as input.</description>
        <name>forN_ValidIssueQty</name>
        <dataType>Number</dataType>
        <expression>IF( {!forB_ValidIssueQuantity}, {!IssueQty}, 1)</expression>
        <scale>0</scale>
    </formulas>
    <formulas>
        <description>Processed or Expired depending on the Choice Pre-Closure status: Open - Processed, Expired then Expired</description>
        <name>forT_MemberBenefitClosureStatus</name>
        <dataType>String</dataType>
        <expression>IF ( {!varT_ChoicePreCloseStatus} == &quot;Expired&quot;, &quot;Expired&quot;, &quot;Processed&quot;)</expression>
    </formulas>
