    <decisions>
        <name>Member_Choice_Status</name>
        <label>Member Choice Status?</label>
        <locationX>0</locationX>
        <locationY>0</locationY>
        <defaultConnector>
            <targetReference>Assignment_No_Valid_Benefit</targetReference>
        </defaultConnector>
        <defaultConnectorLabel>Default Outcome</defaultConnectorLabel>
        <rules>
            <name>Outcome_Open_NewExpiration</name>
            <conditionLogic>(2 AND 4) AND (1 OR 3)</conditionLogic>
            <conditions>
                <leftValueReference>Get_Member_Choice.Status__c</leftValueReference>
                <operator>EqualTo</operator>
                <rightValue>
                    <stringValue>Open</stringValue>
                </rightValue>
            </conditions>
            <conditions>
                <leftValueReference>IssueQty</leftValueReference>
                <operator>LessThanOrEqualTo</operator>
                <rightValue>
                    <elementReference>Get_Member_Choice.Number_of_Choices__c</elementReference>
                </rightValue>
            </conditions>
            <conditions>
                <leftValueReference>Get_Member_Choice.Status__c</leftValueReference>
                <operator>EqualTo</operator>
                <rightValue>
                    <stringValue>Expired</stringValue>
                </rightValue>
            </conditions>
            <conditions>
                <leftValueReference>Get_Member_Choice.Processed__c</leftValueReference>
                <operator>EqualTo</operator>
                <rightValue>
                    <booleanValue>false</booleanValue>
                </rightValue>
            </conditions>
            <connector>
                <targetReference>Choice_Option</targetReference>
            </connector>
            <label>Status-Open or Newly Expired</label>
        </rules>
        <rules>
            <name>Status_Expired_Closed</name>
            <conditionLogic>or</conditionLogic>
            <conditions>
                <leftValueReference>Get_Member_Choice.Status__c</leftValueReference>
                <operator>EqualTo</operator>
                <rightValue>
                    <stringValue>Closed</stringValue>
                </rightValue>
            </conditions>
            <connector>
                <targetReference>Response_Closed</targetReference>
            </connector>
            <label>Status-Expired or Closed</label>
        </rules>
        <rules>
            <name>Insufficient_Selections_Available</name>
            <conditionLogic>and</conditionLogic>
            <conditions>
                <leftValueReference>Get_Member_Choice.Status__c</leftValueReference>
                <operator>EqualTo</operator>
                <rightValue>
                    <stringValue>Open</stringValue>
                </rightValue>
            </conditions>
            <conditions>
                <leftValueReference>Get_Member_Choice.Number_of_Choices__c</leftValueReference>
                <operator>LessThan</operator>
                <rightValue>
                    <elementReference>IssueQty</elementReference>
                </rightValue>
            </conditions>
            <connector>
                <targetReference>Set_Output_Insufficient_Selections_Available</targetReference>
            </connector>
            <label>Insufficient Selections Available</label>
        </rules>
    </decisions>
