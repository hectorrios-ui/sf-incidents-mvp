    <decisions>
        <description>Determine if there are any remaining selections available.  For instance, for some Member Choice Benefits, the number of selectable choices may be more than one, in which case the system needs to post additional choice selections for the default option.</description>
        <name>Any_Remaining_Selections</name>
        <label>Any Remaining Selections?</label>
        <locationX>867</locationX>
        <locationY>955</locationY>
        <defaultConnector>
            <targetReference>Success</targetReference>
        </defaultConnector>
        <defaultConnectorLabel>Default Outcome</defaultConnectorLabel>
        <rules>
            <name>Yes_More_Selections_Remain</name>
            <conditionLogic>and</conditionLogic>
            <conditions>
                <leftValueReference>varN_NumChoices</leftValueReference>
                <operator>GreaterThan</operator>
                <rightValue>
                    <numberValue>0.0</numberValue>
                </rightValue>
            </conditions>
            <connector>
                <targetReference>Call_Post_Choice_Selection_Flow</targetReference>
            </connector>
            <label>Yes, More Selections Remain</label>
        </rules>
    </decisions>
    <decisions>
        <description>Did we find a Choice Option for this Member Choice where the Default Selection field is set to True?  If so, then post the selection.</description>
        <name>Default_Choice_Option_Found</name>
        <label>Default Choice Option Found</label>
        <locationX>554</locationX>
        <locationY>626</locationY>
        <defaultConnector>
            <targetReference>Update_this_Member_Choice</targetReference>
        </defaultConnector>
        <defaultConnectorLabel>Default Outcome</defaultConnectorLabel>
        <rules>
            <name>Yes_found_matching_record</name>
            <conditionLogic>and</conditionLogic>
            <conditions>
                <leftValueReference>Get_Default_Choice_Option.Id</leftValueReference>
                <operator>IsNull</operator>
                <rightValue>
                    <booleanValue>false</booleanValue>
                </rightValue>
            </conditions>
            <connector>
                <targetReference>Call_Post_Choice_Selection_Flow</targetReference>
            </connector>
            <label>Default Option Found.</label>
        </rules>
    </decisions>
    <decisions>
        <name>Default_Choice_Option_Selection</name>
        <label>Auto Award Default Choice Upon Expiration</label>
        <locationX>395</locationX>
        <locationY>406</locationY>
        <defaultConnector>
            <targetReference>Update_this_Member_Choice</targetReference>
        </defaultConnector>
        <defaultConnectorLabel>Disabled (Default Outcome)</defaultConnectorLabel>
        <rules>
            <name>Enabled_Outcome</name>
            <conditionLogic>and</conditionLogic>
            <conditions>
                <leftValueReference>$Permission.Auto_Award_Default_Option_Upon_Choice_Expiration</leftValueReference>
                <operator>EqualTo</operator>
                <rightValue>
                    <booleanValue>true</booleanValue>
                </rightValue>
            </conditions>
            <connector>
                <targetReference>Get_Default_Choice_Option</targetReference>
            </connector>
            <label>Enabled</label>
        </rules>
    </decisions>
    <description>DE66358 - Issue resolution - account for the status update of member choice and member benefit where no default choice definition rule is present.</description>
    <environments>Default</environments>
    <formulas>
        <description>Protective formula: Returns the Voucher Choice Quantity from the CDR if it is valid (greater than 0), otherwise return 1.</description>
        <name>forN_VoucherChoiceQuantity</name>
        <dataType>Number</dataType>
        <expression>IF ( {!Get_Default_Choice_Option.Choice_Definition_Rule__r.Voucher_Choice_Quantity__c} &gt; 0, {!Get_Default_Choice_Option.Choice_Definition_Rule__r.Voucher_Choice_Quantity__c}, 1)</expression>
        <scale>0</scale>
    </formulas>
