    <recordLookups>
        <description>Query for the default Choice Option for this Member Choice record...</description>
        <name>Get_Default_Choice_Option</name>
        <label>Get Default Choice Option</label>
        <locationX>399</locationX>
        <locationY>721</locationY>
        <assignNullValuesIfNoRecordsFound>false</assignNullValuesIfNoRecordsFound>
        <connector>
            <targetReference>Default_Choice_Option_Found</targetReference>
        </connector>
        <filterLogic>and</filterLogic>
        <filters>
            <field>Default_Choice__c</field>
            <operator>EqualTo</operator>
            <value>
                <booleanValue>true</booleanValue>
            </value>
        </filters>
        <filters>
            <field>Member_Choice__c</field>
            <operator>EqualTo</operator>
            <value>
                <elementReference>$Record.Id</elementReference>
            </value>
        </filters>
        <getFirstRecordOnly>true</getFirstRecordOnly>
        <object>Choice_Option__c</object>
        <storeOutputAutomatically>true</storeOutputAutomatically>
    </recordLookups>
    <recordUpdates>
        <description>...likeise the Member Benefit status must be updated to Expired if there is no default selection.</description>
        <name>Set_Member_Benefit_Status_to_Expired</name>
