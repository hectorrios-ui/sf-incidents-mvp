                <elementReference>Determine_Face_Value_and_Currency.varCurrencyISOCode</elementReference>
            </value>
        </inputAssignments>
        <inputAssignments>
            <field>Face_Value__c</field>
            <value>
                <elementReference>Determine_Face_Value_and_Currency.varFaceValue</elementReference>
            </value>
        </inputAssignments>
        <inputReference>$Record</inputReference>
    </recordUpdates>
    <recordUpdates>
        <name>Update_Choice_Option_0</name>
        <label>Update Choice Option</label>
        <locationX>0</locationX>
        <locationY>0</locationY>
        <inputAssignments>
            <field>CurrencyIsoCode</field>
            <value>
                <stringValue></stringValue>
            </value>
        </inputAssignments>
        <inputAssignments>
            <field>Face_Value__c</field>
        </inputAssignments>
        <inputReference>$Record</inputReference>
    </recordUpdates>
    <start>
        <locationX>0</locationX>
        <locationY>0</locationY>
        <connector>
            <targetReference>Get_Member</targetReference>
        </connector>
        <object>Choice_Option__c</object>
        <recordTriggerType>Create</recordTriggerType>
        <triggerType>RecordAfterSave</triggerType>
    </start>
    <status>Active</status>
    <subflows>
        <name>Determine_Face_Value_and_Currency</name>
        <label>Determine Face Value and Currency</label>
        <locationX>0</locationX>
        <locationY>0</locationY>
        <connector>
            <targetReference>Update_Choice_Option</targetReference>
        </connector>
        <flowName>LOY_Voucher_Determine_FV_and_Currency</flowName>
        <inputAssignments>
            <name>inMember</name>
