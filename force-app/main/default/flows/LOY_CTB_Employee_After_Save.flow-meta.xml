    <recordUpdates>
        <name>Set_RecalculateBenefits_to_false_If_true</name>
        <label>Set RecalculateBenefits to false If true</label>
        <locationX>176</locationX>
        <locationY>539</locationY>
        <connector>
            <targetReference>Save_Log_Action2</targetReference>
        </connector>
        <faultConnector>
            <targetReference>Log_Errors_when_Update_failed</targetReference>
        </faultConnector>
        <filterLogic>and</filterLogic>
        <filters>
            <field>RecalculateBenefits__c</field>
            <operator>EqualTo</operator>
            <value>
                <booleanValue>true</booleanValue>
            </value>
        </filters>
        <inputAssignments>
            <field>RecalculateBenefits__c</field>
            <value>
                <booleanValue>false</booleanValue>
            </value>
        </inputAssignments>
        <inputReference>$Record</inputReference>
    </recordUpdates>
    <start>
        <locationX>50</locationX>
        <locationY>0</locationY>
        <connector>
            <targetReference>Calculate_GM_Start_Date_Tenure</targetReference>
        </connector>
        <filterFormula>ISPICKVAL({!$Record.Loyalty_Program_Member__r.MemberStatus}, &apos;Active&apos;) &amp;&amp;
	(	
		(
               ISNEW() &amp;&amp; 
              (
                 ISPICKVAL({!$Record.EmployeeStatus}, &apos;Active&apos;) || 
                 ISPICKVAL({!$Record.EmployeeStatus}, &apos;Terminated&apos;) ||
                 ISPICKVAL({!$Record.EmployeeStatus}, &apos;On_Leave&apos;) ||
                 ISPICKVAL({!$Record.EmployeeStatus}, &apos;Suspended&apos;)
              ) &amp;&amp; 
              (
                 NOT(ISPICKVAL({!$Record.Employee_Group__c}, &apos;&apos;)) &amp;&amp; 
                 NOT(ISPICKVAL({!$Record.Employee_Sub_Group__c}, &apos;&apos;))
              )
         )
        ||
        (
             (
             NOT(ISNEW()) &amp;&amp; 
             (
                ISCHANGED({!$Record.EmployeeStatus}) &amp;&amp; 
                (ISPICKVAL({!$Record.EmployeeStatus}, &apos;Active&apos;) || 
                ISPICKVAL({!$Record.EmployeeStatus}, &apos;Terminated&apos;) ||
                ISPICKVAL({!$Record.EmployeeStatus}, &apos;On_Leave&apos;) ||
                ISPICKVAL({!$Record.EmployeeStatus}, &apos;Suspended&apos;))
             )
			) 
         || 
            (
            NOT(ISNEW()) &amp;&amp; 
             (
                (ISCHANGED({!$Record.Employee_Group__c}) || 
                ISCHANGED({!$Record.Employee_Sub_Group__c}) ||
                ({!$Record.RecalculateBenefits__c})
              )
             )
             )
        )
	)</filterFormula>
        <object>Employee</object>
        <recordTriggerType>CreateAndUpdate</recordTriggerType>
        <triggerType>RecordAfterSave</triggerType>
    </start>
    <status>Active</status>
