    <description>Upgrade or extend a loyalty member tier and align benefit and tier expiry dates based on a configurable expiry model.</description>
    <environments>Default</environments>
    <formulas>
        <name>BenefitExpiryDate</name>
        <dataType>Date</dataType>
        <expression>CASE({!TierExpiryModel},
&quot;End of Current Year&quot;,DATE(YEAR(TODAY()),12,31),
&quot;End of Next Year&quot;,DATE(YEAR(TODAY())+1,12,31),
&quot;Year After Next (2 Years)&quot;,DATE(YEAR(TODAY())+2,12,31),
&quot;Lifetime&quot;, null,
NULL)</expression>
    </formulas>
    <formulas>
        <name>ChangeReason</name>
        <dataType>String</dataType>
        <expression>BLANKVALUE({!Get_Member_Benefit_Record.PrimaryRefObjectRecordTitle}, &quot;Partner Benefit&quot;)</expression>
    </formulas>
    <formulas>
        <name>TierExpiryDate</name>
        <dataType>Date</dataType>
        <expression>CASE({!TierExpiryModel},
&quot;End of Current Year&quot;,DATE(YEAR(TODAY()),12,31),
&quot;End of Next Year&quot;,DATE(YEAR(TODAY())+1,12,31),
&quot;Year After Next (2 Years)&quot;,DATE(YEAR(TODAY())+2,12,31),
&quot;Lifetime&quot;, null,
NULL)</expression>
    </formulas>
