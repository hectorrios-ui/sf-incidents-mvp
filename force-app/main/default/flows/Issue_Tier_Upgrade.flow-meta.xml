    <decisions>
        <name>Can_Upgrade</name>
        <label>Can Upgrade?</label>
        <locationX>0</locationX>
        <locationY>0</locationY>
        <defaultConnector>
            <isGoTo>true</isGoTo>
            <targetReference>Save_Log</targetReference>
        </defaultConnector>
        <defaultConnectorLabel>No</defaultConnectorLabel>
        <rules>
            <name>Yes</name>
            <conditionLogic>and</conditionLogic>
            <conditions>
                <leftValueReference>Get_Member_Tier.SequenceNumber</leftValueReference>
                <operator>LessThan</operator>
                <rightValue>
                    <elementReference>Get_Target_Tier.SequenceNumber</elementReference>
                </rightValue>
            </conditions>
            <connector>
                <targetReference>Check_Tier</targetReference>
            </connector>
            <label>Yes</label>
        </rules>
        <rules>
            <name>May_Be</name>
            <conditionLogic>3 AND (( 1 AND 2) OR (1 AND 4))</conditionLogic>
            <conditions>
                <leftValueReference>Get_Member_Current_Loyalty_Tier_Record.TierExpirationDate</leftValueReference>
                <operator>IsNull</operator>
                <rightValue>
                    <booleanValue>false</booleanValue>
                </rightValue>
            </conditions>
            <conditions>
                <leftValueReference>Get_Member_Current_Loyalty_Tier_Record.TierExpirationDate</leftValueReference>
                <operator>LessThan</operator>
                <rightValue>
                    <elementReference>TierExpiryDate</elementReference>
                </rightValue>
            </conditions>
            <conditions>
                <leftValueReference>Get_Member_Current_Loyalty_Tier_Record.LoyaltyTier.SequenceNumber</leftValueReference>
                <operator>EqualTo</operator>
                <rightValue>
                    <elementReference>Get_Target_Tier.SequenceNumber</elementReference>
                </rightValue>
            </conditions>
            <conditions>
                <leftValueReference>TierExpiryDate</leftValueReference>
                <operator>IsNull</operator>
                <rightValue>
                    <booleanValue>true</booleanValue>
                </rightValue>
            </conditions>
            <connector>
                <targetReference>Update_Tier_Expiry</targetReference>
            </connector>
            <label>May Be</label>
        </rules>
    </decisions>
    <decisions>
        <name>Check_Tier</name>
