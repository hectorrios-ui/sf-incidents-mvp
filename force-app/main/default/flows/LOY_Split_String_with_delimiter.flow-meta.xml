    <formulas>
        <name>Multiselect_Display_split</name>
        <dataType>String</dataType>
        <expression>LEFT( {!Multiselect_Input_String}, FIND({!SEPERATOR},  {!Multiselect_Input_String})-1)</expression>
    </formulas>
    <formulas>
        <name>Multiselect_Display_substitute</name>
        <dataType>String</dataType>
        <expression>RIGHT({!Multiselect_Input_String}, LEN({!Multiselect_Input_String})-FIND(&apos;,&apos;,  {!Multiselect_Input_String}))</expression>
    </formulas>
    <formulas>
        <name>Occurrences_of_comma_max</name>
        <dataType>Number</dataType>
        <expression>(LEN({!Multiselect_Input_String}) - LEN(SUBSTITUTE(LOWER({!Multiselect_Input_String}),&quot;,&quot;,&quot;&quot;)))</expression>
        <scale>0</scale>
    </formulas>
