    <apiVersion>65.0</apiVersion>
    <areMetricsLoggedToDataCloud>false</areMetricsLoggedToDataCloud>
    <assignments>
        <name>Update_Voucher_fields</name>
        <label>Update Voucher fields</label>
        <locationX>0</locationX>
        <locationY>0</locationY>
        <assignmentItems>
            <assignToReference>Issued_Voucher.EffectiveDate</assignToReference>
            <operator>Assign</operator>
            <value>
                <elementReference>Get_Member_Benefit.StartDate</elementReference>
            </value>
        </assignmentItems>
        <assignmentItems>
            <assignToReference>Issued_Voucher.ExpirationDate</assignToReference>
            <operator>Assign</operator>
            <value>
                <elementReference>Get_Member_Benefit.EndDate</elementReference>
            </value>
        </assignmentItems>
        <assignmentItems>
            <assignToReference>Issued_Voucher.Member_Benefit__c</assignToReference>
            <operator>Assign</operator>
            <value>
                <elementReference>MemberBenefitId</elementReference>
            </value>
        </assignmentItems>
        <connector>
            <targetReference>Multiple_vouchers</targetReference>
        </connector>
    </assignments>
    <constants>
        <name>FlowName</name>
        <dataType>String</dataType>
        <value>
            <stringValue>Issue Loyalty Voucher</stringValue>
        </value>
    </constants>
    <decisions>
        <description>A simple while loop</description>
        <name>Multiple_vouchers</name>
        <label>Multiple vouchers</label>
        <locationX>0</locationX>
        <locationY>0</locationY>
        <defaultConnector>
            <targetReference>Link_Vouchers_to_Member_Benefit</targetReference>
        </defaultConnector>
        <defaultConnectorLabel>No</defaultConnectorLabel>
        <rules>
            <name>Yes</name>
            <conditionLogic>and</conditionLogic>
            <conditions>
                <leftValueReference>voucherAssignmentCount</leftValueReference>
                <operator>GreaterThan</operator>
                <rightValue>
                    <numberValue>1.0</numberValue>
                </rightValue>
            </conditions>
            <connector>
                <targetReference>Clone_Issued_Vouchers</targetReference>
            </connector>
            <label>Yes</label>
        </rules>
    </decisions>
    <environments>Default</environments>
    <formulas>
        <name>copiesToMake</name>
        <dataType>Number</dataType>
        <expression>{!voucherAssignmentCount} - 1</expression>
        <scale>2</scale>
    </formulas>
    <formulas>
        <description>Determines if the startDate should be Today or the MemberBenefit.StartDate.</description>
        <name>latestStartDate</name>
        <dataType>Date</dataType>
        <expression>IF({!Get_Member_Benefit.StartDate}&gt;{!$Flow.CurrentDate}, {!Get_Member_Benefit.StartDate}, {!$Flow.CurrentDate})</expression>
    </formulas>
    <formulas>
        <description>Determines the entire amount of vouchers that must be assigned.</description>
        <name>voucherAssignmentCount</name>
        <dataType>Number</dataType>
        <expression>MAX(1,{!VoucherIssueCount}) * MAX(1,{!Get_Voucher_Definition.How_Many__c})</expression>
        <scale>2</scale>
    </formulas>
    <formulas>
        <name>voucherCode</name>
        <dataType>String</dataType>
        <expression>{!$Flow.InterviewGuid}</expression>
    </formulas>
