    <description>US415293 CTB| Upon expiring a member benefit, set group LPMs and LPGMRs inactive
Combining the Logic of Deactivating and Reactivating the Group LPM &amp; LPGMR&apos;s dynamically
DE114567 - Exception Email at &quot;LOY CTB Reactivate/Deactivate Group LPM &amp; LPGMR If MB Status Either Processed/Expired&quot; Flow</description>
    <environments>Default</environments>
    <formulas>
        <name>CalculateQueryGroupLPMStatusBasedonMBStatus</name>
        <dataType>String</dataType>
        <expression>IF(ISPICKVAL({!$Record.Status}, &apos;Processed&apos;), &apos;Inactive&apos;, &apos;Active&apos;)</expression>
    </formulas>
    <formulas>
        <name>CalculateQueryLPGMRStatusBasedonMBStatus</name>
        <dataType>Boolean</dataType>
        <expression>IF(ISPICKVAL({!$Record.Status}, &apos;Processed&apos;), false, true)</expression>
    </formulas>
    <formulas>
        <name>CalculateUpdateGroupLPMStatusBasedonMBStatus</name>
        <dataType>String</dataType>
        <expression>IF(ISPICKVAL({!$Record.Status}, &apos;Processed&apos;), &apos;Active&apos;, &apos;Inactive&apos;)</expression>
    </formulas>
    <formulas>
        <name>CalculateUpdateLPGMREndDateBasedonMBStatus</name>
        <dataType>Date</dataType>
        <expression>IF(ISPICKVAL({!$Record.Status}, &apos;Processed&apos;), null, {!$Flow.CurrentDate})</expression>
    </formulas>
    <formulas>
        <name>CalculateUpdateLPGMRStatusBasedonMBStatus</name>
        <dataType>Boolean</dataType>
        <expression>IF(ISPICKVAL({!$Record.Status}, &apos;Processed&apos;), true, false)</expression>
    </formulas>
    <interviewLabel>LOY CTB Inactive Group LPM &amp; LPGMR If MB Status Expired {!$Flow.CurrentDateTime}</interviewLabel>
