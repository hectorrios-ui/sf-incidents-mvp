    </recordCreates>
    <recordCreates>
        <description>Creates Contact Point Phone for Individual. All fields must be set in the previous element.</description>
        <name>CreateContactPointPhoneForIndividual</name>
        <label>Create Contact Point Phone for Individual</label>
        <locationX>0</locationX>
        <locationY>0</locationY>
        <connector>
            <targetReference>CreateDefaultOptInCommSubscriptionConsents</targetReference>
        </connector>
