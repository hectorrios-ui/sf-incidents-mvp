    <decisions>
        <description>Checks if the Contact has an email address</description>
        <name>IsContactEmailNull</name>
        <label>Is Contact Email null?</label>
        <locationX>0</locationX>
        <locationY>0</locationY>
        <defaultConnector>
            <targetReference>IsContactPhoneNull</targetReference>
        </defaultConnector>
        <defaultConnectorLabel>Yes, it&apos;s null</defaultConnectorLabel>
        <rules>
            <name>IsContactEmailNull_No</name>
            <conditionLogic>and</conditionLogic>
            <conditions>
                <leftValueReference>$Record.Email</leftValueReference>
                <operator>IsNull</operator>
                <rightValue>
                    <booleanValue>false</booleanValue>
                </rightValue>
            </conditions>
            <connector>
                <targetReference>PrepareContactPointEmailRecord</targetReference>
            </connector>
            <label>No, it&apos;s populated</label>
        </rules>
    </decisions>
    <decisions>
        <description>Checks if the Contact has a phone</description>
        <name>IsContactPhoneNull</name>
        <label>Is Contact Phone null?</label>
        <locationX>0</locationX>
        <locationY>0</locationY>
        <defaultConnector>
            <targetReference>CreateDefaultOptInCommSubscriptionConsents</targetReference>
        </defaultConnector>
        <defaultConnectorLabel>Yes, it&apos;s null</defaultConnectorLabel>
        <rules>
            <name>IsContactPhoneNull_No</name>
            <conditionLogic>and</conditionLogic>
            <conditions>
                <leftValueReference>$Record.Phone</leftValueReference>
                <operator>IsNull</operator>
                <rightValue>
                    <booleanValue>false</booleanValue>
                </rightValue>
            </conditions>
            <connector>
                <targetReference>PrepareContactPointPhoneRecord</targetReference>
            </connector>
            <label>No, it&apos;s populated</label>
        </rules>
    </decisions>
    <decisions>
        <description>Checks if Individual Id on Contact is null in order to understand the further steps. If it&apos;s null, we need to create records, if it&apos;s not - all necessary records have already been created.</description>
        <name>IsIndividualIdNull</name>
        <label>Is Individual Id null?</label>
        <locationX>0</locationX>
        <locationY>0</locationY>
        <defaultConnector>
            <targetReference>PrepareIndividualRecord</targetReference>
        </defaultConnector>
        <defaultConnectorLabel>Yes, it&apos;s null</defaultConnectorLabel>
        <rules>
            <name>IsIndividualIdNull_No</name>
            <conditionLogic>and</conditionLogic>
            <conditions>
                <leftValueReference>$Record.IndividualId</leftValueReference>
                <operator>IsNull</operator>
                <rightValue>
                    <booleanValue>false</booleanValue>
                </rightValue>
            </conditions>
            <label>No, it&apos;s populated</label>
        </rules>
    </decisions>
    <description>Creates Individual and Contact Point records when a Member Contact is created or an existing contact is changed to a Member Contact.</description>
    <environments>Default</environments>
    <formulas>
        <description>Error message to be logged for the case when a Contact Point Email record creation failed</description>
        <name>FailedToCreateContactPointEmailErrorMessage</name>
        <dataType>String</dataType>
        <expression>&quot;Failed to create a Contact Point Email record for the Contact with ID=&quot; + {!$Record.Id}</expression>
    </formulas>
    <formulas>
        <description>Error message to be logged for the case when a Contact Point Phone record creation failed</description>
        <name>FailedToCreateContactPointPhoneErrorMessage</name>
        <dataType>String</dataType>
        <expression>&quot;Failed to create a Contact Point Phone record for the Contact with ID=&quot; + {!$Record.Id}</expression>
    </formulas>
    <formulas>
        <description>Error message to be logged for the case when an Individual record creation failed</description>
        <name>FailedToCreateIndividualErrorMessage</name>
        <dataType>String</dataType>
        <expression>&quot;Failed to create an Individual record for the Contact with ID=&quot; + {!$Record.Id}</expression>
    </formulas>
    <formulas>
        <description>Error message to be logged for the case when a Contact record update failed</description>
        <name>FailedToUpdateContactErrorMessage</name>
        <dataType>String</dataType>
        <expression>&quot;Failed to update the Contact (ID=&quot; + {!$Record.Id} + &quot;) with the Individual lookup; the Individual record creation was rolled back&quot;</expression>
    </formulas>
