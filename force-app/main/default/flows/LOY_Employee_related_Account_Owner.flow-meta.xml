    <apiVersion>65.0</apiVersion>
    <areMetricsLoggedToDataCloud>false</areMetricsLoggedToDataCloud>
    <constants>
        <name>FlowName</name>
        <dataType>String</dataType>
        <value>
            <stringValue>Employee related Account Owner</stringValue>
        </value>
    </constants>
    <decisions>
        <name>Check_related_Account_Owner_Role</name>
        <label>Check related Account Owner Role</label>
        <locationX>0</locationX>
        <locationY>0</locationY>
        <defaultConnector>
            <targetReference>Default_Account_Owner</targetReference>
        </defaultConnector>
        <defaultConnectorLabel>Doesn&apos;t have owner</defaultConnectorLabel>
        <rules>
            <name>Has_Owner</name>
            <conditionLogic>and</conditionLogic>
            <conditions>
                <leftValueReference>relatedAccountOwnerHasRole</leftValueReference>
                <operator>EqualTo</operator>
                <rightValue>
                    <booleanValue>true</booleanValue>
                </rightValue>
            </conditions>
            <label>Has Owner</label>
        </rules>
    </decisions>
    <description>Checks if the Owner of the Account related to the LPM (via the Contact) has a role so that the employee can have a portal user created for them if they access the CTB Experience Portal.</description>
    <environments>Default</environments>
    <formulas>
        <description>Id of the Account linked to the LPM via the Contact</description>
        <name>relatedAccountId</name>
        <dataType>String</dataType>
        <expression>{!$Record.Loyalty_Program_Member__r.Contact.AccountId}</expression>
    </formulas>
    <formulas>
        <description>Checks if the Owner of the Account related to the LPM (via the Contact) has a role.</description>
        <name>relatedAccountOwnerHasRole</name>
        <dataType>Boolean</dataType>
        <expression>NOT(ISBLANK({!$Record.Loyalty_Program_Member__r.Contact.Account.Owner.UserRoleId}))</expression>
    </formulas>
    <interviewLabel>Employee related Account Owner {!$Flow.CurrentDateTime}</interviewLabel>
    <label>Employee related Account Owner</label>
    <processMetadataValues>
        <name>BuilderType</name>
        <value>
            <stringValue>LightningFlowBuilder</stringValue>
        </value>
    </processMetadataValues>
    <processMetadataValues>
        <name>CanvasMode</name>
        <value>
            <stringValue>AUTO_LAYOUT_CANVAS</stringValue>
        </value>
    </processMetadataValues>
    <processMetadataValues>
        <name>OriginBuilderType</name>
        <value>
            <stringValue>LightningFlowBuilder</stringValue>
        </value>
    </processMetadataValues>
    <processType>AutoLaunchedFlow</processType>
    <recordLookups>
        <name>Default_Account_Owner</name>
        <label>Default Account Owner</label>
        <locationX>0</locationX>
        <locationY>0</locationY>
        <assignNullValuesIfNoRecordsFound>false</assignNullValuesIfNoRecordsFound>
        <connector>
            <targetReference>Set_Default_Owner</targetReference>
        </connector>
        <faultConnector>
            <targetReference>Default_Owner_not_found</targetReference>
        </faultConnector>
        <filterLogic>and</filterLogic>
        <filters>
            <field>Name</field>
            <operator>EqualTo</operator>
            <value>
                <elementReference>$Label.Default_Account_Owner</elementReference>
            </value>
        </filters>
        <filters>
            <field>IsActive</field>
            <operator>EqualTo</operator>
            <value>
                <booleanValue>true</booleanValue>
            </value>
        </filters>
        <getFirstRecordOnly>true</getFirstRecordOnly>
        <object>User</object>
        <storeOutputAutomatically>true</storeOutputAutomatically>
    </recordLookups>
    <recordUpdates>
        <name>Set_Default_Owner</name>
        <label>Set Default Owner</label>
        <locationX>0</locationX>
        <locationY>0</locationY>
        <faultConnector>
            <targetReference>Failed_to_update_Account_Owner</targetReference>
        </faultConnector>
        <filterLogic>and</filterLogic>
        <filters>
            <field>Id</field>
            <operator>EqualTo</operator>
            <value>
                <elementReference>$Record.Loyalty_Program_Member__r.Contact.AccountId</elementReference>
            </value>
        </filters>
        <inputAssignments>
            <field>OwnerId</field>
            <value>
                <elementReference>Default_Account_Owner.Id</elementReference>
            </value>
        </inputAssignments>
        <object>Account</object>
    </recordUpdates>
    <start>
        <locationX>0</locationX>
        <locationY>0</locationY>
        <connector>
            <targetReference>Check_related_Account_Owner_Role</targetReference>
        </connector>
        <filterFormula>AND(
    NOT(ISBLANK({!$Record.Loyalty_Program_Member__c})),
    OR(
        ISNEW(),
        ISCHANGED({!$Record.Loyalty_Program_Member__c})
    )
)</filterFormula>
        <object>Employee</object>
        <recordTriggerType>CreateAndUpdate</recordTriggerType>
        <triggerType>RecordAfterSave</triggerType>
    </start>
    <status>Active</status>
    <textTemplates>
        <name>AccountUpdateErrorMessage</name>
