    <decisions>
        <name>Any_Tiers_to_Expire</name>
        <label>Any Tiers to Expire</label>
        <locationX>0</locationX>
        <locationY>0</locationY>
        <defaultConnector>
            <targetReference>Commit_Updates_to_Member_Tiers</targetReference>
        </defaultConnector>
        <defaultConnectorLabel>Default Outcome</defaultConnectorLabel>
        <rules>
            <name>No_Tiers_to_Expire</name>
            <conditionLogic>or</conditionLogic>
            <conditions>
                <leftValueReference>varN_NumberOfTiersToExpire</leftValueReference>
                <operator>LessThan</operator>
                <rightValue>
                    <numberValue>1.0</numberValue>
                </rightValue>
            </conditions>
            <label>No Tiers to Expire</label>
        </rules>
    </decisions>
    <decisions>
        <description>If there are less than two member tiers then there is no need to proceed as this flow is triggered when a new member tier is created for the purposes of expiring the previos.  So if there is only one member tier then it must be the one that triggered this flow which is the active one.</description>
        <name>Number_of_Member_Tiers</name>
        <label>Number of Member Tiers</label>
        <locationX>0</locationX>
        <locationY>0</locationY>
        <defaultConnector>
            <targetReference>DateLoop</targetReference>
        </defaultConnector>
        <defaultConnectorLabel>2 Or More</defaultConnectorLabel>
        <rules>
            <name>Less_Than_2</name>
            <conditionLogic>and</conditionLogic>
            <conditions>
                <leftValueReference>varN_NumberOfMemberTiers</leftValueReference>
                <operator>LessThan</operator>
                <rightValue>
                    <numberValue>2.0</numberValue>
                </rightValue>
            </conditions>
            <connector>
                <targetReference>Set_Flow_Error_Message</targetReference>
            </connector>
            <label>Less Than 2</label>
        </rules>
    </decisions>
    <decisions>
        <name>Tier_to_Be_Expired</name>
        <label>Tier to Be Expired</label>
        <locationX>0</locationX>
        <locationY>0</locationY>
        <defaultConnector>
            <targetReference>DateLoop</targetReference>
        </defaultConnector>
        <defaultConnectorLabel>Default Outcome</defaultConnectorLabel>
        <rules>
            <name>Tier_Meets_Criteria</name>
            <conditionLogic>(1 OR 2) AND 3</conditionLogic>
            <conditions>
                <leftValueReference>DateLoop.TierExpirationDate</leftValueReference>
                <operator>IsNull</operator>
                <rightValue>
                    <booleanValue>true</booleanValue>
                </rightValue>
            </conditions>
            <conditions>
                <leftValueReference>DateLoop.TierExpirationDate</leftValueReference>
                <operator>GreaterThanOrEqualTo</operator>
                <rightValue>
                    <elementReference>forD_Today</elementReference>
                </rightValue>
            </conditions>
            <conditions>
                <leftValueReference>DateLoop.Id</leftValueReference>
                <operator>NotEqualTo</operator>
                <rightValue>
                    <elementReference>varR_NewMemberTier.Id</elementReference>
                </rightValue>
            </conditions>
            <connector>
                <targetReference>Set_Exp_Date</targetReference>
            </connector>
            <label>Tier Meets Criteria</label>
        </rules>
    </decisions>
    <description>Called by the Member Tier RTF. Uses the expiration date to determine which Member Tiers to expire.</description>
    <formulas>
        <name>forD_Today</name>
        <dataType>Date</dataType>
        <expression>TODAY()</expression>
    </formulas>
    <formulas>
        <description>Determines the value of the Tier to expire based on Change Type.  EG. If New Tier sequence number is 4 and change type is upgrade, formula will return 3.  If change type is downgrade, formula will return 5.</description>
        <name>forN_MemTierSecNumToExpire</name>
        <dataType>Number</dataType>
        <expression>CASE( {!varR_NewMemberTier.ChangeReasonType}, &apos;Achieve&apos;,  {!varR_NewMemberTier.Tier_Sequence_Number__c}-1, &apos;Downgrade&apos;, {!varR_NewMemberTier.Tier_Sequence_Number__c}+1, -999)</expression>
        <scale>0</scale>
    </formulas>
    <interviewLabel>LOY - Subflow - Expire Member Tier per Exp Date {!$Flow.CurrentDateTime}</interviewLabel>
    <label>LOY - Subflow - Expire Member Tier per Exp Date</label>
