    </formulas>
    <formulas>
        <name>IsEmployeeStatusFound</name>
        <dataType>Boolean</dataType>
        <expression>TEXT({!Get_Employee.EmployeeStatus})= TEXT({!Iterate_Over_Retiree_Employee_Rules.Employee_Status__c})</expression>
    </formulas>
    <formulas>
        <description>Checks if Employee Sub Group Exists</description>
        <name>IsEmployeeSubGroupExist</name>
        <dataType>Boolean</dataType>
        <expression>AND(
OR(
    {!Multiselect_Display_collection} = &quot;[]&quot;,
    CONTAINS({!Multiselect_Display_collection}, TEXT({!Get_Employee.Employee_Sub_Group__c}))
),
NOT(ISBLANK(TEXT({!Get_Employee.Employee_Sub_Group__c})))
)</expression>
    </formulas>
    <formulas>
        <description>This flag is used to check if the Employee Tenure falls with in the defined rules in Retiree Employee Rule object Min and Max ranges , updated this formula for US382794</description>
        <name>IsEmployeeTenureMatch</name>
        <dataType>Boolean</dataType>
        <expression>OR( ISBLANK({!Get_Employee.Years__c}),
    AND(
        (
            {!Get_Employee.Years__c}&gt;=
            IF(
                ISBLANK({!Iterate_Over_Retiree_Employee_Rules.Minimal_Tenure_Years__c}) || 
                {!Iterate_Over_Retiree_Employee_Rules.Minimal_Tenure_Years__c} = 0,
                0,
                {!Iterate_Over_Retiree_Employee_Rules.Minimal_Tenure_Years__c}
            )
            ),
        (
            {!Get_Employee.Years__c} &lt;= 
            IF(
                ISBLANK({!Iterate_Over_Retiree_Employee_Rules.Maximum_Tenure_Years__c}) || 
                {!Iterate_Over_Retiree_Employee_Rules.Maximum_Tenure_Years__c} = 0,
                99999,
                {!Iterate_Over_Retiree_Employee_Rules.Maximum_Tenure_Years__c}
            )
        )
    )
)</expression>
    </formulas>
    <formulas>
        <description>Used to check Tenure is matched as per rules.

99999 = Representing &quot;unlimited&quot; as a large number</description>
        <name>IsTenureMatch</name>
        <dataType>Boolean</dataType>
        <expression>AND(
        {!IsEmployeeStatusFound},
        {!IsEmployeeSubGroupExist},
        {!IsEmployeeTenureMatch},
        NOT(ISBLANK(TEXT({!Get_Employee.Employee_Group__c})))
)</expression>
    </formulas>
    <formulas>
        <description>Sets the Selected Employee Group based on the conditions of number of years</description>
        <name>SelectedEmployeeGroup</name>
        <dataType>String</dataType>
        <expression>If(  
OR( OR(({!Get_Employee.Years__c}  &lt; 10) ,   ISBLANK({!Get_Employee.Years__c} )),

AND(
ISBLANK({!Iterate_Over_Retiree_Employee_Rules.Maximum_Tenure_Years__c}) ,
({!Iterate_Over_Retiree_Employee_Rules.Minimal_Tenure_Years__c}==0 ) 
)
), &apos;&apos; , TEXT({!Get_Employee.Employee_Group__c}) 
)</expression>
    </formulas>
