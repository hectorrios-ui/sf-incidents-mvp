        <defaultConnector>
            <targetReference>Raise_Error_If_Employee_Exist</targetReference>
        </defaultConnector>
        <defaultConnectorLabel>Default Outcome</defaultConnectorLabel>
        <rules>
            <name>Yes_RcMemberId</name>
            <conditionLogic>or</conditionLogic>
            <conditions>
                <leftValueReference>Get_Employee_Record.EmployeeNumber</leftValueReference>
