    <start>
        <locationX>276</locationX>
        <locationY>0</locationY>
        <connector>
            <targetReference>Is_NEW_Record</targetReference>
        </connector>
        <filterFormula>OR( IsNew(), 
IsChanged({!$Record.Worker_HR_Org_Type__c}), IsChanged({!$Record.EmployeeNumber}), IsChanged({!$Record.Primary_Work_Country_Code__c}), IsChanged({!$Record.Primary_Work_Location__c}), IsChanged({!$Record.RC_member_ID__c}), ISCHANGED({!$Record.EmployeeStatus})
)</filterFormula>
        <object>Employee</object>
        <recordTriggerType>CreateAndUpdate</recordTriggerType>
        <triggerType>RecordBeforeSave</triggerType>
    </start>
    <status>Active</status>
</Flow>
