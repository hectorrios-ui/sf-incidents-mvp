    <description>US348665 - GOLS: Salesforce: Record-Triggered Flow to Populate Brand and Chain look-up on Hotel Account Records</description>
    <environments>Default</environments>
    <formulas>
        <name>varBrandExceptionDetails</name>
        <dataType>String</dataType>
        <expression>IF(({!$Record.Brandx__c = null}) &amp;&amp; ({!$Record.Brand__c != null}), &apos;No matching Brand code was found for &apos;+{!$Record.Brand__c}, &apos;&apos;)</expression>
