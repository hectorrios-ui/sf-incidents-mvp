    <decisions>
        <name>Check_Different_Field_Conditions</name>
        <label>Check Different Field Conditions</label>
        <locationX>710</locationX>
        <locationY>431</locationY>
        <defaultConnector>
            <targetReference>Assign_Currency_Field_Value</targetReference>
        </defaultConnector>
        <defaultConnectorLabel>Default Outcome</defaultConnectorLabel>
        <rules>
            <name>Dates_Are_Negative</name>
            <conditionLogic>(1 OR 2 OR 3 ) AND  4</conditionLogic>
            <conditions>
                <leftValueReference>$Record.LOY_CheckInDate__c</leftValueReference>
                <operator>IsNull</operator>
                <rightValue>
                    <booleanValue>true</booleanValue>
                </rightValue>
            </conditions>
            <conditions>
                <leftValueReference>$Record.LOY_CheckoutDate__c</leftValueReference>
                <operator>IsNull</operator>
                <rightValue>
                    <booleanValue>true</booleanValue>
                </rightValue>
            </conditions>
            <conditions>
                <leftValueReference>$Record.LOY_CheckInDate__c</leftValueReference>
                <operator>GreaterThan</operator>
                <rightValue>
                    <elementReference>$Record.LOY_CheckoutDate__c</elementReference>
                </rightValue>
            </conditions>
            <conditions>
                <leftValueReference>isDateChecked</leftValueReference>
                <operator>EqualTo</operator>
                <rightValue>
                    <booleanValue>false</booleanValue>
                </rightValue>
            </conditions>
            <connector>
                <targetReference>Assign_Date_Notes</targetReference>
            </connector>
            <label>Dates Are Negative</label>
        </rules>
        <rules>
            <name>Hotel_Code_Is_Present</name>
            <conditionLogic>and</conditionLogic>
            <conditions>
                <leftValueReference>$Record.LOY_PropertyCode__c</leftValueReference>
                <operator>IsNull</operator>
                <rightValue>
                    <booleanValue>false</booleanValue>
                </rightValue>
            </conditions>
            <conditions>
                <leftValueReference>isHotelChecked</leftValueReference>
                <operator>EqualTo</operator>
                <rightValue>
                    <booleanValue>false</booleanValue>
                </rightValue>
            </conditions>
            <connector>
                <targetReference>Get_Hotel_Record</targetReference>
            </connector>
            <label>Hotel Code Is Present</label>
        </rules>
        <rules>
            <name>Hotel_Code_Is_not_Present</name>
            <conditionLogic>and</conditionLogic>
            <conditions>
                <leftValueReference>$Record.LOY_PropertyCode__c</leftValueReference>
                <operator>IsNull</operator>
                <rightValue>
                    <booleanValue>true</booleanValue>
                </rightValue>
            </conditions>
            <conditions>
                <leftValueReference>blankHotelCodeChecked</leftValueReference>
                <operator>EqualTo</operator>
                <rightValue>
                    <booleanValue>false</booleanValue>
                </rightValue>
            </conditions>
            <connector>
                <targetReference>Assign_Blank_Hotel_Notes</targetReference>
            </connector>
            <label>Hotel Code Is not Present</label>
        </rules>
        <rules>
            <name>Rate_Category_is_Present</name>
            <conditionLogic>and</conditionLogic>
            <conditions>
                <leftValueReference>$Record.LOY_FinalRateCategory__c</leftValueReference>
                <operator>IsNull</operator>
                <rightValue>
                    <booleanValue>false</booleanValue>
                </rightValue>
            </conditions>
            <conditions>
                <leftValueReference>isRateCategoryChecked</leftValueReference>
                <operator>EqualTo</operator>
                <rightValue>
                    <booleanValue>false</booleanValue>
                </rightValue>
            </conditions>
            <connector>
                <targetReference>Get_Rate_Category_Record</targetReference>
            </connector>
            <label>Rate Category is Present</label>
        </rules>
    </decisions>
