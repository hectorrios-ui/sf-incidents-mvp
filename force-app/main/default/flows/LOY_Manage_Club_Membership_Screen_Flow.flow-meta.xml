    <decisions>
        <description>If the current tier is either KIC or RAM we must also close the other one.</description>
        <name>open_KIC_or_RAM_tier</name>
        <label>KIC or RAM tier</label>
        <locationX>0</locationX>
        <locationY>0</locationY>
        <defaultConnector>
            <targetReference>Navigate_LoyaltyMemberTier_Screen</targetReference>
        </defaultConnector>
