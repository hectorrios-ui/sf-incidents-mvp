    <decisions>
        <description>Checks to see if the expiration date is in the past.</description>
        <name>Check_if_Tier_is_expired</name>
        <label>Check if Tier is expired</label>
        <locationX>0</locationX>
        <locationY>0</locationY>
        <defaultConnector>
            <targetReference>Member_Tier_Re_open_confirmation</targetReference>
        </defaultConnector>
        <defaultConnectorLabel>Default Outcome</defaultConnectorLabel>
        <rules>
            <name>Tier_expired</name>
            <conditionLogic>and</conditionLogic>
            <conditions>
                <leftValueReference>Get_Loyalty_Member_Tier_Record.TierExpirationDate</leftValueReference>
                <operator>LessThanOrEqualTo</operator>
                <rightValue>
                    <elementReference>$Flow.CurrentDate</elementReference>
                </rightValue>
            </conditions>
            <connector>
                <targetReference>Expired_Tier</targetReference>
            </connector>
            <label>Tier expired</label>
        </rules>
    </decisions>
    <decisions>
        <name>Check_LoyaltyMemberTier_Status</name>
        <label>Check LoyaltyMemberTier Status</label>
        <locationX>0</locationX>
        <locationY>0</locationY>
        <defaultConnector>
            <targetReference>Navigate_LoyaltyMemberTier_Screen</targetReference>
        </defaultConnector>
        <defaultConnectorLabel>Default Outcome</defaultConnectorLabel>
        <rules>
            <name>Is_LoyaltyMemberTier_Open</name>
            <conditionLogic>and</conditionLogic>
            <conditions>
                <leftValueReference>Get_Loyalty_Member_Tier_Record.ClubMembershipStatusCode__c</leftValueReference>
                <operator>EqualTo</operator>
                <rightValue>
