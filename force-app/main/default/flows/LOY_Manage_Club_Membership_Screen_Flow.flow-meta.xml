            </connector>
            <label>Is LoyaltyMemberTier Open</label>
        </rules>
        <rules>
            <name>Is_LoyaltyMemberTier_Closed</name>
            <conditionLogic>and</conditionLogic>
            <conditions>
                <leftValueReference>Get_Loyalty_Member_Tier_Record.ClubMembershipStatusCode__c</leftValueReference>
                <operator>EqualTo</operator>
                <rightValue>
                    <stringValue>C</stringValue>
                </rightValue>
            </conditions>
            <connector>
                <targetReference>Is_LoyaltyProgramMember_Active</targetReference>
            </connector>
            <label>Is LoyaltyMemberTier Closed</label>
        </rules>
    </decisions>
    <decisions>
        <description>If the current tier is either KIC or RAM we must also close the other one.</description>
        <name>close_KIC_or_RAM_tier</name>
