    <decisions>
        <name>Open_Tier</name>
        <label>Open Tier</label>
        <locationX>0</locationX>
        <locationY>0</locationY>
        <defaultConnector>
            <targetReference>Closed_tiers</targetReference>
        </defaultConnector>
        <defaultConnectorLabel>No</defaultConnectorLabel>
        <rules>
            <name>Yes_Open</name>
            <conditionLogic>and</conditionLogic>
            <conditions>
                <leftValueReference>Closed_tiers.LoyaltyTier.Name</leftValueReference>
                <operator>EqualTo</operator>
                <rightValue>
                    <elementReference>otherMemberTier</elementReference>
                </rightValue>
            </conditions>
            <connector>
                <targetReference>Re_Open_Other_Member_Tier</targetReference>
            </connector>
            <label>Yes</label>
        </rules>
    </decisions>
    <description>Created as part of US429630 || AMB | Close membership
Updated as part of US432712 || AMB |  Reopen of the membership
Updated as part of US453607 || AMB| Manage Membership Pop Up
Updated as part of US443317 || AMB | Ambassador membership cannot be reopened if LPM status = Closed</description>
    <environments>Default</environments>
    <formulas>
        <name>isRAMorKIC</name>
        <dataType>Boolean</dataType>
        <expression>OR(
    {!Get_Loyalty_Member_Tier_Record.LoyaltyTier.Name} == &apos;Royal Ambassador&apos;,
    {!Get_Loyalty_Member_Tier_Record.LoyaltyTier.Name} == &apos;Kimpton Inner Circle&apos;
)</expression>
    </formulas>
    <formulas>
        <description>If the triggering Member Tier is RAM then this will be KIC or vice versa.</description>
        <name>otherMemberTier</name>
        <dataType>String</dataType>
        <expression>CASE(
{!Get_Loyalty_Member_Tier_Record.LoyaltyTier.Name}, 
&apos;Royal Ambassador&apos;, &apos;Kimpton Inner Circle&apos;, 
&apos;Kimpton Inner Circle&apos;, &apos;Royal Ambassador&apos;,
&apos;INVALID&apos;
)</expression>
    </formulas>
