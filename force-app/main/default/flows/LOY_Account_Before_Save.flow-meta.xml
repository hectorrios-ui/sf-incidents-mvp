    <decisions>
        <name>Record_Type_Check</name>
        <label>Record Type Check</label>
        <locationX>182</locationX>
        <locationY>287</locationY>
        <defaultConnectorLabel>Default Outcome</defaultConnectorLabel>
        <rules>
            <name>Hotel_Property_Record_Type_Check</name>
            <conditionLogic>and</conditionLogic>
            <conditions>
                <leftValueReference>$Record.RecordType.DeveloperName</leftValueReference>
                <operator>EqualTo</operator>
                <rightValue>
                    <stringValue>Hotel_Property</stringValue>
                </rightValue>
            </conditions>
            <connector>
                <targetReference>Update_Is_Hotel_Record</targetReference>
            </connector>
            <label>Hotel Property Record Type Check</label>
        </rules>
    </decisions>
    <description>Within the HCR processing, when an Account record is created for a hotel, auto set the Account.Is_Hotel_Record__c is set to True.</description>
