                <elementReference>$Record</elementReference>
            </value>
        </inputAssignments>
        <inputAssignments>
            <name>MemberNumber</name>
            <value>
                <elementReference>$Record.Loyalty_Program_Member__r.MembershipNumber</elementReference>
            </value>
        </inputAssignments>
        <inputAssignments>
