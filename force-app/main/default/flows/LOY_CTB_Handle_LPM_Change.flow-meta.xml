        </connector>
        <flowName>CTB_Active_Member_Benefit_Assignment</flowName>
        <inputAssignments>
            <name>recordId</name>
            <value>
                <elementReference>$Record.Id</elementReference>
            </value>
        </inputAssignments>
    </subflows>
    <subflows>
        <name>Awards_GM_Platinum_Lifetime_Voucher_to_new_LPM</name>
