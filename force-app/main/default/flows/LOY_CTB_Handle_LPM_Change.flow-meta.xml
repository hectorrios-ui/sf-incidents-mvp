        <label>Transfer CTB Benefit Counters</label>
        <locationX>0</locationX>
        <locationY>0</locationY>
        <connector>
            <targetReference>GM_Platinum_Voucher</targetReference>
        </connector>
        <flowName>LOY_Transfer_CTB_Benefit_Counters</flowName>
        <inputAssignments>
            <name>NewLPMId</name>
            <value>
                <elementReference>$Record.Loyalty_Program_Member__c</elementReference>
            </value>
        </inputAssignments>
        <inputAssignments>
            <name>OldLPMId</name>
            <value>
                <elementReference>$Record__Prior.Loyalty_Program_Member__c</elementReference>
            </value>
        </inputAssignments>
    </subflows>
