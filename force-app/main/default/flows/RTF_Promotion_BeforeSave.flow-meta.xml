<?xml version="1.0" encoding="UTF-8"?>
<Flow xmlns="http://soap.sforce.com/2006/04/metadata">
    <apiVersion>65.0</apiVersion>
    <areMetricsLoggedToDataCloud>false</areMetricsLoggedToDataCloud>
    <assignments>
        <name>Convert_To_UpperCase</name>
        <label>Convert To UpperCase</label>
        <locationX>0</locationX>
        <locationY>0</locationY>
        <assignmentItems>
            <assignToReference>$Record.PromotionCode</assignToReference>
            <operator>Assign</operator>
            <value>
                <elementReference>PromotionCodeInUpperCase</elementReference>
            </value>
        </assignmentItems>
    </assignments>
    <decisions>
        <description>Generic node to capture entry criteria for diff before save logics</description>
        <name>Entry_Criteria</name>
        <label>Entry Criteria</label>
        <locationX>0</locationX>
        <locationY>0</locationY>
        <defaultConnectorLabel>Default Outcome</defaultConnectorLabel>
        <rules>
            <name>Check_for_Promotion_Code_Field</name>
            <conditionLogic>and</conditionLogic>
            <conditions>
                <leftValueReference>$Record.PromotionCode</leftValueReference>
                <operator>IsBlank</operator>
                <rightValue>
                    <booleanValue>false</booleanValue>
                </rightValue>
            </conditions>
            <connector>
                <targetReference>Convert_To_UpperCase</targetReference>
            </connector>
            <label>Check for Promotion Code Field</label>
        </rules>
    </decisions>
    <environments>Default</environments>
    <formulas>
        <name>PromotionCodeInUpperCase</name>
        <dataType>String</dataType>
        <expression>UPPER({!$Record.PromotionCode})</expression>
    </formulas>
    <interviewLabel>RTF_Promotion_BeforeSave {!$Flow.CurrentDateTime}</interviewLabel>
    <label>RTF_Promotion_BeforeSave</label>
    <processMetadataValues>
        <name>BuilderType</name>
        <value>
            <stringValue>LightningFlowBuilder</stringValue>
        </value>
    </processMetadataValues>
    <processMetadataValues>
        <name>CanvasMode</name>
        <value>
            <stringValue>AUTO_LAYOUT_CANVAS</stringValue>
        </value>
    </processMetadataValues>
    <processMetadataValues>
        <name>OriginBuilderType</name>
        <value>
            <stringValue>LightningFlowBuilder</stringValue>
        </value>
    </processMetadataValues>
    <processType>AutoLaunchedFlow</processType>
    <start>
        <locationX>0</locationX>
        <locationY>0</locationY>
        <connector>
            <targetReference>Entry_Criteria</targetReference>
        </connector>
        <object>Promotion</object>
        <recordTriggerType>CreateAndUpdate</recordTriggerType>
        <triggerType>RecordBeforeSave</triggerType>
    </start>
    <status>Active</status>
</Flow>
