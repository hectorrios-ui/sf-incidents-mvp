        <defaultConnectorLabel>Default Outcome</defaultConnectorLabel>
        <rules>
            <name>Auto_Redeem_Voucher</name>
            <conditionLogic>and</conditionLogic>
            <conditions>
                <leftValueReference>var_Voucher.VoucherDefinition.Redemption_Channel__c</leftValueReference>
