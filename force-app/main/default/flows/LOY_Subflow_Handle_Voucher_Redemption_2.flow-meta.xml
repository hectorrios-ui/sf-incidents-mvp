            </connector>
            <label>Redeemed</label>
        </rules>
    </decisions>
    <environments>Default</environments>
    <formulas>
        <name>forB_IsEligible</name>
        <dataType>Boolean</dataType>
        <expression>AND ( 
{!var_Voucher.LoyaltyProgramMember.MembershipStatusCode__c} = &quot;O&quot;, ISPICKVAL({!var_Voucher.Status}, &quot;Redeemed&quot;)
)</expression>
