<?xml version="1.0" encoding="UTF-8"?>
<Flow xmlns="http://soap.sforce.com/2006/04/metadata">
    <apiVersion>65.0</apiVersion>
    <areMetricsLoggedToDataCloud>false</areMetricsLoggedToDataCloud>
    <decisions>
        <name>Is_record_New_or_Updated</name>
        <label>Is record New or Updated</label>
        <locationX>0</locationX>
        <locationY>0</locationY>
        <defaultConnectorLabel>Updated</defaultConnectorLabel>
        <rules>
            <name>New_Outcome</name>
            <conditionLogic>and</conditionLogic>
            <conditions>
                <leftValueReference>varF_IsNew</leftValueReference>
                <operator>EqualTo</operator>
                <rightValue>
                    <booleanValue>true</booleanValue>
                </rightValue>
            </conditions>
            <connector>
                <targetReference>Expire_Member_Tiers</targetReference>
            </connector>
            <label>New</label>
        </rules>
    </decisions>
    <description>Checking to date centric expiration flow.</description>
    <formulas>
        <description>Represents if the record is new.</description>
        <name>varF_IsNew</name>
        <dataType>Boolean</dataType>
        <expression>ISNEW()</expression>
    </formulas>
    <interviewLabel>LOY - Member Tier After Update {!$Flow.CurrentDateTime}</interviewLabel>
    <label>LOY - Member Tier After Update</label>
    <processMetadataValues>
        <name>BuilderType</name>
        <value>
            <stringValue>LightningFlowBuilder</stringValue>
        </value>
    </processMetadataValues>
    <processMetadataValues>
        <name>CanvasMode</name>
        <value>
            <stringValue>AUTO_LAYOUT_CANVAS</stringValue>
        </value>
    </processMetadataValues>
    <processMetadataValues>
        <name>OriginBuilderType</name>
        <value>
            <stringValue>LightningFlowBuilder</stringValue>
        </value>
    </processMetadataValues>
    <processType>AutoLaunchedFlow</processType>
    <start>
        <locationX>0</locationX>
        <locationY>0</locationY>
        <connector>
            <targetReference>Is_record_New_or_Updated</targetReference>
        </connector>
        <object>LoyaltyMemberTier</object>
        <recordTriggerType>CreateAndUpdate</recordTriggerType>
        <triggerType>RecordAfterSave</triggerType>
    </start>
    <status>Active</status>
    <subflows>
        <name>Expire_Member_Tiers</name>
        <label>Expire Member Tiers</label>
        <locationX>0</locationX>
        <locationY>0</locationY>
        <flowName>LOY_Subflow_Expire_Member_Tier_per_Exp_Date</flowName>
        <inputAssignments>
            <name>varR_NewMemberTier</name>
            <value>
                <elementReference>$Record</elementReference>
            </value>
        </inputAssignments>
        <storeOutputAutomatically>true</storeOutputAutomatically>
    </subflows>
</Flow>
