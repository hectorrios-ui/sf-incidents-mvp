    </formulas>
    <formulas>
        <name>journalTypeName</name>
        <dataType>String</dataType>
        <expression>IF( {!newTierStatus} = &apos;Active&apos;, &apos;Club Activation&apos;, &apos;Club Closure&apos;)</expression>
    </formulas>
    <formulas>
        <name>newTierStatus</name>
        <dataType>String</dataType>
        <expression>IF({!newTierStatusCode} = &apos;O&apos;, &apos;Active&apos;, &apos;Inactive&apos;)</expression>
    </formulas>
    <formulas>
        <name>newTierStatusCode</name>
        <dataType>String</dataType>
        <expression>CASE( {!TierStatus}, 
    &apos;Open&apos;, &apos;O&apos;,
    &apos;open&apos;, &apos;O&apos;, 
    &apos;Closed&apos;, &apos;C&apos;,
    &apos;closed&apos;, &apos;C&apos;,
    &apos;C&apos;
)</expression>
    </formulas>
    <formulas>
