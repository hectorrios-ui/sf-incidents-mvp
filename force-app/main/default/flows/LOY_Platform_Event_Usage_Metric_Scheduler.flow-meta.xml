    </textTemplates>
    <textTemplates>
        <name>customExceptionDetails</name>
        <isViewedAsPlainText>true</isViewedAsPlainText>
        <text>Usage Metric Date: {!NOW}; Events Published: {!platformEventsDeliveryCount}; Threshold: {!platformEvent_Min_Threshold}</text>
    </textTemplates>
