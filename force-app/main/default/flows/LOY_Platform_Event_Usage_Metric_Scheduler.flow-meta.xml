            <value>
                <elementReference>PlatformEventUsage_DateTime</elementReference>
            </value>
        </filters>
        <filters>
            <field>EndDate</field>
            <operator>LessThan</operator>
            <value>
                <elementReference>NOW</elementReference>
            </value>
        </filters>
        <getFirstRecordOnly>false</getFirstRecordOnly>
        <object>PlatformEventUsageMetric</object>
        <storeOutputAutomatically>true</storeOutputAutomatically>
    </recordLookups>
