    <decisions>
        <name>Check_for_Delivery_Threshold</name>
        <label>Check for Delivery Threshold</label>
        <locationX>176</locationX>
        <locationY>660</locationY>
        <defaultConnector>
            <targetReference>Get_Platform_Event_Collab_Group</targetReference>
        </defaultConnector>
        <defaultConnectorLabel>Default Outcome</defaultConnectorLabel>
        <rules>
            <name>Threshold_Exceeded</name>
            <conditionLogic>and</conditionLogic>
            <conditions>
                <leftValueReference>platformEventsDeliveryCount</leftValueReference>
                <operator>GreaterThan</operator>
                <rightValue>
                    <elementReference>platformEvent_Min_Threshold</elementReference>
                </rightValue>
            </conditions>
            <label>Threshold Exceeded</label>
        </rules>
    </decisions>
    <description>This flow is used to send an event/message to Loyalty Program Group in case of Platform event downtime.</description>
    <environments>Default</environments>
    <formulas>
        <name>formula_Combined_Error_Message</name>
        <dataType>String</dataType>
        <expression>&quot;//////Debug Notes: &quot; &amp;  {!var_DebugNotes} &amp; &quot;//////Exception Details: &quot; &amp; {!var_ExceptionDetails} &amp;  &quot;//////Operation: &quot; &amp; {!var_Operation}</expression>
    </formulas>
    <formulas>
        <name>NOW</name>
        <dataType>DateTime</dataType>
        <expression>NOW()</expression>
    </formulas>
    <formulas>
        <name>platformEvent_Min_Threshold</name>
        <dataType>Number</dataType>
        <expression>VALUE({!$Label.LOY_Platform_Event_Delivery_Daily_Minimum})</expression>
        <scale>0</scale>
    </formulas>
    <formulas>
        <name>PlatformEventUsage_DateTime</name>
        <dataType>DateTime</dataType>
        <expression>NOW() - 1</expression>
    </formulas>
    <interviewLabel>LOY - {!$Flow.CurrentDateTime}</interviewLabel>
