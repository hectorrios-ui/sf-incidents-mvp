    <recordLookups>
        <name>Get_Platform_Event_Usage_Metrics</name>
        <label>Get Platform Event Usage Metrics</label>
        <locationX>176</locationX>
        <locationY>252</locationY>
        <assignNullValuesIfNoRecordsFound>false</assignNullValuesIfNoRecordsFound>
        <connector>
            <targetReference>Iterate_on_Platform_Event_Usage_Metrics</targetReference>
        </connector>
        <faultConnector>
            <targetReference>Assign_Custom_Exception_Values</targetReference>
        </faultConnector>
        <filterLogic>and</filterLogic>
        <filters>
            <field>Name</field>
            <operator>EqualTo</operator>
            <value>
                <stringValue>PLATFORM_EVENTS_DELIVERED</stringValue>
            </value>
        </filters>
        <filters>
            <field>EndDate</field>
