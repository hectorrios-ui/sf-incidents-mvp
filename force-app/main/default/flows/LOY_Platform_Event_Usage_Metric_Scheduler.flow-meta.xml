    <status>Active</status>
    <textTemplates>
        <name>chatterPostMessage</name>
        <isViewedAsPlainText>true</isViewedAsPlainText>
        <text>&lt;p&gt;Hi, According to the Platform Event Usage Metrics for yesterday, the number of Platform Event messages delivered to client systems is below the expected threshold.&lt;/p&gt;&lt;p&gt;&amp;nbsp;&lt;/p&gt;&lt;p&gt;This may indicate that the client systems are offline and may be missing events published by Salesforce.&amp;nbsp;Therefore, we strongly recommend you work with the application teams to confirm that their systems are online and receiving Platform Events as expected.&lt;/p&gt;&lt;p&gt;&amp;nbsp;&lt;/p&gt;&lt;p&gt;&lt;b&gt;Details:&lt;/b&gt;&lt;/p&gt;&lt;p&gt;&lt;b&gt;Usage Metric Date:&lt;/b&gt; {!NOW}&lt;/p&gt;&lt;p&gt;&lt;b&gt;Events Published:&lt;/b&gt; {!platformEventsDeliveryCount}&lt;/p&gt;&lt;p&gt;&lt;b&gt;Threshold: &lt;/b&gt;{!platformEvent_Min_Threshold}&lt;/p&gt;</text>
    </textTemplates>
    <textTemplates>
        <name>customException_DebugNotes</name>
