    <decisions>
        <name>Check_Conversion_Rate_found_or_not</name>
        <label>Check Conversion Rate found or not</label>
        <locationX>182</locationX>
        <locationY>539</locationY>
        <defaultConnector>
            <targetReference>Assign_Status_Note</targetReference>
        </defaultConnector>
        <defaultConnectorLabel>Default Outcome</defaultConnectorLabel>
        <rules>
            <name>Conversion_Rate_found</name>
            <conditionLogic>and</conditionLogic>
            <conditions>
                <leftValueReference>Get_Currency_Rate.rate</leftValueReference>
                <operator>GreaterThan</operator>
                <rightValue>
                    <numberValue>0.0</numberValue>
                </rightValue>
            </conditions>
            <connector>
                <targetReference>Assign_Conversion_Rate</targetReference>
            </connector>
            <label>Conversion Rate found</label>
        </rules>
    </decisions>
    <decisions>
        <name>Check_ISO_Code_and_Checkin_Date</name>
        <label>Check ISO Code and Checkin Date</label>
        <locationX>512</locationX>
        <locationY>323</locationY>
        <defaultConnectorLabel>Default Outcome</defaultConnectorLabel>
        <rules>
            <name>If_non_USD_code_and_checkin_date</name>
            <conditionLogic>and</conditionLogic>
            <conditions>
                <leftValueReference>$Record.CurrencyIsoCode</leftValueReference>
                <operator>NotEqualTo</operator>
                <rightValue>
                    <stringValue>USD</stringValue>
                </rightValue>
            </conditions>
            <conditions>
                <leftValueReference>$Record.CurrencyIsoCode</leftValueReference>
                <operator>IsNull</operator>
                <rightValue>
                    <booleanValue>false</booleanValue>
                </rightValue>
            </conditions>
            <conditions>
                <leftValueReference>$Record.LOY_CheckoutDate__c</leftValueReference>
                <operator>IsNull</operator>
                <rightValue>
                    <booleanValue>false</booleanValue>
                </rightValue>
            </conditions>
            <connector>
                <targetReference>Get_Currency_Rate</targetReference>
            </connector>
            <label>If non USD code and checkin date</label>
        </rules>
        <rules>
            <name>If_USD_Code</name>
            <conditionLogic>and</conditionLogic>
            <conditions>
                <leftValueReference>$Record.CurrencyIsoCode</leftValueReference>
                <operator>EqualTo</operator>
                <rightValue>
                    <stringValue>USD</stringValue>
                </rightValue>
            </conditions>
            <connector>
                <targetReference>Set_Conversion_Rate_to_1</targetReference>
            </connector>
            <label>If USD Code</label>
        </rules>
    </decisions>
    <description>Record Trigger Flow triggered for USD Conversion of the Stay revenues when the sub status update from Data Validated to USD Converted.</description>
