    <description>US438622 - RAM | Process F&amp;B Voucher-STRETCH for QA
US457103 || RAM| Vouchers Expiration date</description>
    <environments>Default</environments>
    <formulas>
        <name>Expiration_End_Year</name>
        <dataType>Date</dataType>
        <expression>IF(
    ISBLANK({!Get_LoyaltyMemberTier_Record.EffectiveDate}),
    NULL,
    DATE(
        YEAR({!Get_LoyaltyMemberTier_Record.EffectiveDate}),
        12,
        31
    )
)</expression>
    </formulas>
    <formulas>
        <name>ExpirationDate</name>
        <dataType>Date</dataType>
        <expression>DATE(
YEAR(ADDMONTHS({!$Flow.CurrentDate},13)),
MONTH(ADDMONTHS({!$Flow.CurrentDate},13)), 
1)</expression>
    </formulas>
    <formulas>
        <name>Is_RAM_OR_KIC</name>
        <dataType>Boolean</dataType>
        <expression>OR(
        LOWER({!Get_LoyaltyTierGroup.Name}) = LOWER({!$Label.LOY_Kimpton_Inner_Circle_Label_Text}),
        LOWER({!Get_LoyaltyTierGroup.Name}) = LOWER({!$Label.LOY_Royal_Ambassador_Label_Text})
)</expression>
    </formulas>
