    <description>Created as part of US432776 || AMB |  Close Ambassador Membership when LPM is Perm Closed
Test Class - LOYManageLMPMembershipAutoFlowTest
Updated as part of US450388 || KIC| Close KIC when LPM is Perm closed
Updated as part of LCT-2443 || RAM| Close RAM when  LPM is Perm closed</description>
    <environments>Default</environments>
    <formulas>
        <name>AMB_Program_Code</name>
        <dataType>String</dataType>
        <expression>{!$CustomMetadata.IHG_Loyalty_Program_Code__mdt.AMB.MasterLabel}</expression>
    </formulas>
    <formulas>
        <name>closureReasonFormula</name>
        <dataType>String</dataType>
        <expression>IF(
    {!closureReason} = &quot;Customer Request&quot;,
    &quot;H&quot;,
    &quot;I&quot;
)</expression>
    </formulas>
    <formulas>
        <name>EndDateTime</name>
        <dataType>String</dataType>
        <expression>TEXT({!$Flow.CurrentDateTime})</expression>
    </formulas>
    <formulas>
        <name>FlowName</name>
        <dataType>String</dataType>
        <expression>&apos;LOY Manage LMP Membership for Close State Flow&apos;</expression>
    </formulas>
    <formulas>
        <name>JournalSubTypeFormula</name>
        <dataType>String</dataType>
        <expression>IF(
    TEXT({!Loop_LoyaltyMemberTier_Records.LoyaltyTierGroup.IHG_LOY_Program_Code__c}) = {!AMB_Program_Code},
    {!Get_JournalSubType_of_Ambassador.Id},
    IF(
        TEXT({!Loop_LoyaltyMemberTier_Records.LoyaltyTierGroup.IHG_LOY_Program_Code__c}) = {!KIC_Program_Code},
        {!Get_JournalSubType_of_KIC.Id},
        IF(
            TEXT({!Loop_LoyaltyMemberTier_Records.LoyaltyTierGroup.IHG_LOY_Program_Code__c}) = {!RAM_Program_Code},
            {!Get_JournalSubType_of_RAM.Id},
            &quot;&quot;
        )
    )
)</expression>
    </formulas>
    <formulas>
        <name>KIC_Program_Code</name>
        <dataType>String</dataType>
        <expression>{!$CustomMetadata.IHG_Loyalty_Program_Code__mdt.KIC.MasterLabel}</expression>
    </formulas>
    <formulas>
        <name>MemberTypeFormula</name>
        <dataType>String</dataType>
        <expression>IF(
    TEXT({!Loop_LoyaltyMemberTier_Records.LoyaltyTierGroup.IHG_LOY_Program_Code__c}) = {!AMB_Program_Code},
    {!$Label.LOY_Ambassador_Text},
    IF(
        TEXT({!Loop_LoyaltyMemberTier_Records.LoyaltyTierGroup.IHG_LOY_Program_Code__c}) = {!KIC_Program_Code},
        {!$Label.LOY_Kimpton_Inner_Circle_Label_Text},
        IF(
            TEXT({!Loop_LoyaltyMemberTier_Records.LoyaltyTierGroup.IHG_LOY_Program_Code__c}) = {!RAM_Program_Code},
            {!$Label.LOY_Royal_Ambassador_Label_Text},
            &quot;&quot;
        )
    )
)</expression>
    </formulas>
    <formulas>
        <name>RAM_Program_Code</name>
        <dataType>String</dataType>
        <expression>{!$CustomMetadata.IHG_Loyalty_Program_Code__mdt.RAM.MasterLabel}</expression>
    </formulas>
    <formulas>
        <name>StartDateTime</name>
        <dataType>String</dataType>
        <expression>TEXT({!$Flow.InterviewStartTime})</expression>
    </formulas>
    <formulas>
        <name>tierclosureReasonFormula</name>
        <dataType>String</dataType>
        <expression>IF(
    OR(
        TEXT({!Loop_LoyaltyMemberTier_Records.LoyaltyTierGroup.IHG_LOY_Program_Code__c}) = {!KIC_Program_Code},
        TEXT({!Loop_LoyaltyMemberTier_Records.LoyaltyTierGroup.IHG_LOY_Program_Code__c}) = {!RAM_Program_Code}
    ),
    &quot;Customer Request&quot;,
    IF(
        TEXT({!Loop_LoyaltyMemberTier_Records.LoyaltyTierGroup.IHG_LOY_Program_Code__c}) = {!AMB_Program_Code},
        IF(
            OR(
                {!closureReason} = &quot;IHG Request&quot;,
                {!closureReason} = &quot;Removed&quot;
            ),
            &quot;IHG Request&quot;,
            {!closureReason}
        ),
        {!closureReason}
    )
)</expression>
    </formulas>
