<?xml version="1.0" encoding="UTF-8"?>
<!-- 
    SHELL — no secret included.
    After deploy: Setup → Named Credentials → Slack_Webhook → Edit
    → paste the Slack Incoming Webhook URL into the "URL" field and save.
-->
<NamedCredential xmlns="http://soap.sforce.com/2006/04/metadata">
    <label>Slack Webhook</label>
    <allowMergeFieldsInBody>true</allowMergeFieldsInBody>
    <allowMergeFieldsInHeader>false</allowMergeFieldsInHeader>
    <calloutStatus>Enabled</calloutStatus>
    <generateAuthorizationHeader>false</generateAuthorizationHeader>
    <namedCredentialParameters>
        <parameterName>Url</parameterName>
        <parameterType>Url</parameterType>
        <parameterValue>https://hooks.slack.com/services/REPLACE_ME</parameterValue>
    </namedCredentialParameters>
    <namedCredentialType>SecuredEndpoint</namedCredentialType>
</NamedCredential>
